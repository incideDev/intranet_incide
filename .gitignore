# ---------------------------------------------------------------------------
# Production-safe .gitignore — PHP intranet platform
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Environment / secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

config/.env
config/.env.*
config/.env.local

platform/app/Config/.env
platform/app/Config/.env.local

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
/vendor/
node_modules/

# ---------------------------------------------------------------------------
# Python (cron / import tools)
# ---------------------------------------------------------------------------
.venv/
venv/
env/
__pycache__/
*.pyc
*.pyo

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------------
# Cache / temp
# ---------------------------------------------------------------------------
tmp/
cache/
*.cache

uploads/tmp_cache/
uploads/temp/
uploads/tmp_commesse/

# ---------------------------------------------------------------------------
# Uploads (user generated content)
# ---------------------------------------------------------------------------
uploads/*
!uploads/.gitkeep

# ---------------------------------------------------------------------------
# Office temp files
# ---------------------------------------------------------------------------
~$*.docx
~$*.doc
~$*.xls
~$*.xlsx

# ---------------------------------------------------------------------------
# Backup / legacy files
# ---------------------------------------------------------------------------
*_OLD.js
*_OLD.php
*.php_backup
*.bak
*.tmp

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
dist/
build/
*.min.js.map
*.min.css.map

# ---------------------------------------------------------------------------
# IDE / AI tools
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

.agent/
.claude/

*.local.json
settings.local.json

# ---------------------------------------------------------------------------
# OS junk
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Optional private assets (uncomment if repository becomes public)
# ---------------------------------------------------------------------------
# assets/images/profile_pictures/
# assets/signatures/
# IntLibs/phpWord/templates/*.docx

# ---------------------------------------------------------------------------
# Optional local config overrides
# ---------------------------------------------------------------------------
# config.local.php
# config.dev.php
# core/host_db_server.local.php